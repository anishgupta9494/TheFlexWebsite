# The Flex Client - Environment Variables Example

# API Configuration
VITE_API_URL=http://localhost:3000

# App Configuration
VITE_APP_NAME=The Flex
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true

# External Services
# VITE_STRIPE_PUBLIC_KEY=pk_test_...
# VITE_GA_ID=G-...
